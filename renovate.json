{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "America/Toronto",
  "rebaseWhen": "conflicted",
  "commitBodyTable": true,
  "printConfig": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "enabledManagers": [
    "github-actions",
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump CRD source pins in sources.yaml",
      "fileMatch": ["^sources\\.yaml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: registryUrl=(?<registryUrl>\\S+))?\\n\\s*version: (?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchFileNames": ["sources.yaml"],
      "commitMessageTopic": "CRD source {{depName}}",
      "semanticCommitType": "chore",
      "semanticCommitScope": "sources",
      "addLabels": ["sources"]
    },
    {
      "matchDatasources": ["github-actions"],
      "commitMessageTopic": "github action {{depName}}",
      "semanticCommitType": "chore",
      "semanticCommitScope": "ci",
      "addLabels": ["ci"]
    },
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"]
    },
    {
      "matchUpdateTypes": ["minor"],
      "addLabels": ["minor"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "addLabels": ["patch"]
    }
  ],
  "labels": [
    "renovate"
  ]
}
